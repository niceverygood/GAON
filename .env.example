# ============================================================
# Gaon — Environment Variables
# Copy to `.env.local` and fill in. Never commit `.env.local`.
# ============================================================

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Supabase (Auth + Postgres + Storage) ---
NEXT_PUBLIC_SUPABASE_URL=
# Supabase publishable key (formerly "anon key"). Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only. NEVER expose. Used for admin/cron jobs that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI ---
# Preferred: Anthropic native.
ANTHROPIC_API_KEY=
# Fallback: OpenRouter (OpenAI-compatible). Used automatically when
# ANTHROPIC_API_KEY is not set. Key looks like `sk-or-v1-...`.
OPENROUTER_API_KEY=

# --- Direct Postgres (optional — psql / migration tooling only) ---
# Use the pooler connection string from Supabase → Project Settings → Database.
# Next.js app does NOT need this — it talks to Supabase via the HTTP API.
DATABASE_URL=

# --- CODEF (주민등록 본인인증, 내보험다보여, 심평원, 건강보험공단) ---
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=

# --- 카카오 (소셜 로그인 + 알림톡) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/callback/kakao

# --- 결제 (토스페이먼츠 or PortOne) ---
TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=

# --- 모니터링 ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Cron 인증 (Vercel Cron이 호출하는 엔드포인트 보호) ---
CRON_SECRET=

# --- Demo / Pilot 로그인 (로그인 페이지의 "테스트 계정으로 로그인" 버튼) ---
# 비워 두면 기본값(demo@gaon.app / GaonDemo!2026)을 사용합니다.
# 자동 생성은 SUPABASE_SERVICE_ROLE_KEY 가 설정돼 있을 때만 동작합니다.
TEST_ACCOUNT_EMAIL=
TEST_ACCOUNT_PASSWORD=
TEST_ACCOUNT_NAME=
